{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.leaderaudit.uz" }],
      "destination": "https://leaderaudit.uz/:path*",
      "permanent": true
    },
    { "source": "/tpost/:slug*", "destination": "/blog", "permanent": true },
    { "source": "/uz/tpost/:slug*", "destination": "/uz/blog", "permanent": true },
    { "source": "/en/tpost/:slug*", "destination": "/en/blog", "permanent": true },
    { "source": "/runews", "destination": "/blog", "permanent": true },
    { "source": "/runews/:path*", "destination": "/blog", "permanent": true },
    { "source": "/uznews", "destination": "/uz/blog", "permanent": true },
    { "source": "/uznews/:path*", "destination": "/uz/blog", "permanent": true },
    { "source": "/ennews", "destination": "/en/blog", "permanent": true },
    { "source": "/ennews/:path*", "destination": "/en/blog", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ]
}
